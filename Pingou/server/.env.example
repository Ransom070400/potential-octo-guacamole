# Pingou sponsorship backend — copy to .env (gitignored) and fill in.

# Enoki PRIVATE api key (enoki_private_...). NEVER put this in the app / EXPO_PUBLIC_*.
ENOKI_PRIVATE_KEY=

# Deployed pingou Move package id (same as the app's EXPO_PUBLIC_PINGOU_PACKAGE_ID).
PINGOU_PACKAGE_ID=0xd2b46e84434c141bc5d31e80e7c76376bf9c54e3c416bd84c39997d8c9b3c0ae

SUI_NETWORK=testnet
PORT=8787

# Shared secret required on /sponsor + /execute. Must equal the app's
# EXPO_PUBLIC_SPONSOR_SECRET. Leave blank to run open (dev only). Generate one:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SPONSOR_SECRET=
# Rate limit (per sender address and per IP).
RATE_MAX=30
RATE_WINDOW_MS=60000
