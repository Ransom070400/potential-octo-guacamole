# Supabase (legacy — kept while migrating to Sui behind EXPO_PUBLIC_SUI_ENABLED)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Sui migration ───────────────────────────────────────────────
# Master switch. While false, the app runs the existing Supabase stack untouched.
EXPO_PUBLIC_SUI_ENABLED=false

# Network: testnet | mainnet
EXPO_PUBLIC_SUI_NETWORK=testnet

# Published `pingou` Move package id (filled in after deploy).
EXPO_PUBLIC_PINGOU_PACKAGE_ID=

# Enoki zkLogin — PUBLIC api key only (safe in the client; proving + salt).
# The PRIVATE key lives on the sponsorship backend, never in the app bundle.
EXPO_PUBLIC_ENOKI_PUBLIC_KEY=
# OAuth client ids per provider (from Google/Apple consoles, registered in Enoki).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Walrus HTTP endpoints (testnet defaults; @mysten/walrus SDK can't run on Hermes).
EXPO_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
EXPO_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# Backend that holds the Enoki PRIVATE key and sponsors allowlist `add` txs.
EXPO_PUBLIC_SPONSOR_API_URL=http://localhost:8787
# Shared secret sent to the sponsor backend (must equal its SPONSOR_SECRET).
EXPO_PUBLIC_SPONSOR_SECRET=
